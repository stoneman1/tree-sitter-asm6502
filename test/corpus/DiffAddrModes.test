==========
Different Addressing Modes
==========
lda #$10       ; Immediate
lda $2000      ; Absolute
lda $2000,X    ; Absolute,X
lda $2000,Y    ; Absolute,Y
lda $10        ; Zero Page
lda $10,X      ; Zero Page,X
lda $10,Y      ; Zero Page,Y
lda ($10)      ; Indirect
lda ($10,X)    ; Indirect,X
lda ($10),Y    ; Indirect,Y
